---
// Hero-J: Multi-CTA & Badges - Foco em confiança e autoridade
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
}
const { title, subtitle, btnText, btnLink, bgImage } = Astro.props;
---
<section class="relative bg-white pt-24 pb-32 lg:pt-32 lg:pb-48 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge de destaque -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-50 border border-gray-100 rounded-2xl mb-10 shadow-sm animate-bounce-subtle">
        <span class="flex h-2 w-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none">Novidade 2024</span>
      </div>

      <h1 class="text-5xl md:text-8xl font-black text-dark tracking-tighter leading-[0.9] mb-10">
        {title}
      </h1>
      
      <p class="text-xl text-gray-500 mb-12 max-w-2xl mx-auto font-medium leading-relaxed">
        {subtitle}
      </p>

      <!-- Botões -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
        <a href={btnLink} class="w-full sm:w-auto px-10 py-5 bg-primary text-white font-black rounded-2xl shadow-2xl shadow-primary/40 hover:scale-105 active:scale-95 transition-all text-sm uppercase tracking-widest">
          {btnText}
        </a>
        <a href="#blog" class="w-full sm:w-auto px-10 py-5 bg-white border-2 border-dark text-dark font-black rounded-2xl hover:bg-dark hover:text-white transition-all text-sm uppercase tracking-widest">
          Ver Conteúdo
        </a>
      </div>

      <!-- Trust Badges -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-16 border-t border-gray-100">
        <div class="flex items-center gap-4 text-left group">
          <div class="w-12 h-12 flex-shrink-0 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <h4 class="font-black text-dark text-sm uppercase">100% Verificado</h4>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Fontes confiáveis</p>
          </div>
        </div>
        <div class="flex items-center gap-4 text-left group">
          <div class="w-12 h-12 flex-shrink-0 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h4 class="font-black text-dark text-sm uppercase">Foco Holístico</h4>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Cuidado integral</p>
          </div>
        </div>
        <div class="flex items-center gap-4 text-left group">
          <div class="w-12 h-12 flex-shrink-0 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h4 class="font-black text-dark text-sm uppercase">Suporte Real</h4>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Rede de apoio</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- BG Pattern -->
  <div class="absolute top-[30%] right-[-10%] w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-[150px] -z-10"></div>
  <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full border border-gray-100 -z-10"></div>
</section>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 4s ease-in-out infinite;
  }
</style>